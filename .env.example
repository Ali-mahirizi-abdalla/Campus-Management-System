# ==============================================================================
# STUDENT WELFARE MANAGEMENT SYSTEM (SWMS) - ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit the actual .env file to version control.

# ------------------------------------------------------------------------------
# CORE DJANGO SETTINGS
# ------------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-goes-here
DEBUG=False
# Set to True for local development with SQLite, False for Production (Postgres/MySQL)
USE_SQLITE=True
# Comma-separated list of allowed hosts (e.g., yourdomain.com,www.yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION (For Production)
# ------------------------------------------------------------------------------
# The project supports dj-database-url. You can provide a single DATABASE_URL
# or individual components for MySQL/PostgreSQL.
DATABASE_URL=postgres://user:password@host:port/dbname

# Individual DB fields (if DATABASE_URL is not used)
DB_NAME=swms_db
DB_USER=swms_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# ------------------------------------------------------------------------------
# EMAIL CONFIGURATION (SMTP)
# ------------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ------------------------------------------------------------------------------
# STORAGE CONFIGURATION (Cloudinary/S3)
# ------------------------------------------------------------------------------
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

USE_S3=False
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_REGION_NAME=your_region

# ------------------------------------------------------------------------------
# M-PESA INTEGRATION (Daraja API)
# ------------------------------------------------------------------------------
MPESA_CONSUMER_KEY=your_mpesa_key
MPESA_CONSUMER_SECRET=your_mpesa_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://yourdomain.com/payment/callback/

# ------------------------------------------------------------------------------
# AFRICA'S TALKING (SMS/USSD)
# ------------------------------------------------------------------------------
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_api_key

# ------------------------------------------------------------------------------
# GOOGLE OAUTH
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ------------------------------------------------------------------------------
# REDIS & CELERY
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# TELEGRAM BROADCAST
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
